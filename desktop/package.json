{
  "name": "jakal-flow-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/clean-vite-cache.mjs && vite --host 0.0.0.0 --port 1420",
    "build": "vite build",
    "check:bundle": "node scripts/check-bundle-budgets.mjs",
    "build:budget": "npm run build && npm run check:bundle",
    "prepare:runtime": "node scripts/prepare-runtime.mjs",
    "test": "node --test --test-isolation=none",
    "preview": "vite preview --host 0.0.0.0 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "node scripts/clean-vite-cache.mjs && tauri dev",
    "tauri:build": "node scripts/build-release.mjs full",
    "tauri:build:full": "node scripts/build-release.mjs full",
    "tauri:build:python": "node scripts/build-release.mjs python",
    "tauri:build:lean": "node scripts/build-release.mjs lean",
    "tauri:build:all": "node scripts/build-release.mjs all"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "vite": "^5.4.11"
  }
}
