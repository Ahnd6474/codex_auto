{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jakal-flow Desktop",
  "version": "0.1.0",
  "identifier": "dev.jakal-flow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "jakal-flow Desktop",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
