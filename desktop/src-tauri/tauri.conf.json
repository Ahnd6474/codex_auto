{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codex-auto Desktop",
  "version": "0.1.0",
  "identifier": "dev.codex-auto.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "codex-auto Desktop",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
